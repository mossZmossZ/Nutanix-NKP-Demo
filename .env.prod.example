# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change-me-secure-password

# ── Backend ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

# Admin account (auto-seeded on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# AES-256 key for cluster password encryption (must be exactly 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-chars

# CORS — set to your server IP or hostname (e.g. http://192.168.1.50)
CORS_ORIGIN=http://localhost

# Host IP shown in admin UI for SSH/lab access (auto-detected if unset, but may return wrong interface)
HOST_IP=192.168.1.50

# ── Frontend build args ────────────────────────────────────────────────────────
# /api is relative — works behind nginx reverse proxy on any host
VITE_API_URL=/api

VITE_APP_NAME=Nutanix NKP Demo

# PDF URL — S3 or any public URL to the NKP Setup Guide PDF
VITE_PDF_URL=https://your-bucket.s3.amazonaws.com/NKP-Setup-Guide.pdf
